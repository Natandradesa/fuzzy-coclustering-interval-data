# ==================================================

venv/
.env/
.venv/

# ==================================================
# Jupyter
# ==================================================

.ipynb_checkpoints/

# ==================================================
# VS Code
# ==================================================

.vscode/

# ==================================================
# Operating system files
# ==================================================

.DS_Store
Thumbs.db

# ==================================================
# Build files
# ==================================================

build/
dist/
*.egg-info/

# ==================================================
# Logs
# ==================================================

*.log

# ==================================================
# Temporary files
# ==================================================

*.tmp
*.bak
```
